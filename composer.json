{
    "name": "devswebdev/devtube",
    "description": "A Laravel package for downloading videos from the net by simply passing a URL",
    "type": "library",
    "keywords": [
        "devtube",
        "devswebdev",
        "laravel",
        "downloader",
        "yt-dlp",
        "youtube-dl",
        "laravel-package",
        "mp4",
        "mp3",
        "video downloader",
        "mp3 downloader",
        "media downloader",
        "youtube-downloader",
        "laravel downloader",
        "laravel youtube downloader"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "DevinNorgarb",
            "email": "dnorgarb@gmail.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "illuminate/console": "^12.0|^13.0",
        "illuminate/support": "^12.0|^13.0",
        "norkunas/youtube-dl-php": "^2.0"
    },
    "require-dev": {
        "mockery/mockery": "^1.6",
        "orchestra/testbench": "^10.0|^11.0",
        "phpunit/phpunit": "^11.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "DevsWebDev\\DevTube\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "DevsWebDev\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "config": {
        "sort-packages": true
    },
    "extra": {
        "laravel": {
            "providers": [
                "DevsWebDev\\DevTube\\DevTubeServiceProvider"
            ],
            "aliases": {
                "DevTube": "DevsWebDev\\DevTube\\Facades\\DevTube"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
